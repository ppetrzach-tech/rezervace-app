// Multi-tenant rezervační aplikace (Calendly model).
// Pro produkci stačí změnit `provider` na "postgresql" a upravit DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Firma / účet (multi-tenancy)
model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique // pro URL: /[slug]
  name         String
  tagline      String?
  primaryColor String   @default("2563eb")
  active       Boolean  @default(true)

  // Email vlastníka pro notifikace o nových rezervacích (může být jiný než login email)
  ownerEmail   String?

  // Google Calendar integrace (přes Service Account, sdílený kalendář)
  // Calendar ID typicky email uživatele "petr@gmail.com" nebo "...@group.calendar.google.com"
  googleCalendarId String?
  googleTimezone   String  @default("Europe/Prague")

  createdAt    DateTime @default(now())

  users             User[]
  providers         Provider[]
  services          Service[]
  bookings          Booking[]
  clients           Client[]
  eventListings     EventListing[]
  notificationRules NotificationRule[]
}

// Uživatel admin panelu (vlastník nebo zaměstnanec firmy)
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("staff") // "owner" | "staff"
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerId   String?   @unique
  provider     Provider? @relation(fields: [providerId], references: [id])
  createdAt    DateTime  @default(now())

  @@index([tenantId])
}

// Poskytovatel (osoba, která má rezervace)
model Provider {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  bio          String?
  active       Boolean  @default(true)
  user         User?
  workingHours WorkingHour[]
  services     ServiceProvider[]
  bookings     Booking[]
  timeOff      TimeOff[]
  eventListings EventListing[]
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

// Typ schůzky
model Service {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int
  priceCzk        Int      @default(0)
  showPrice       Boolean  @default(true)
  locationType    String   @default("in_person") // in_person | online | phone | custom
  locationDetail  String?
  bufferBeforeMin Int      @default(0)
  bufferAfterMin  Int      @default(0)
  color           String?
  active          Boolean  @default(true)
  providers       ServiceProvider[]
  bookings        Booking[]
  eventListings   EventListing[]
  createdAt       DateTime @default(now())

  @@index([tenantId])
}

// Vazba M:N mezi službou a poskytovatelem
model ServiceProvider {
  serviceId  String
  providerId String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@id([serviceId, providerId])
}

// Pravidelná pracovní doba
model WorkingHour {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  weekday    Int      // 0 = neděle … 6 = sobota
  startMin   Int
  endMin     Int

  @@unique([providerId, weekday, startMin])
}

// Volno / dovolená / blokace
model TimeOff {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
}

// Klient (rezervující se)
model Client {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String
  bookings  Booking[]
  createdAt DateTime  @default(now())

  @@unique([tenantId, email, phone])
  @@index([tenantId])
}

// Rezervace
model Booking {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id])
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id])
  startsAt        DateTime
  endsAt          DateTime
  status          String   @default("confirmed") // confirmed | cancelled | completed
  note            String?
  reminderSentAt  DateTime?
  // ID události v Google Calendar (pro update/delete)
  googleEventId   String?
  createdAt       DateTime @default(now())

  // Nemovitosti / event listing (volitelné — pro makléřský flow)
  listingId       String?
  listing         EventListing? @relation(fields: [listingId], references: [id])
  eventSlotId     String?       @unique
  eventSlot       EventSlot?    @relation(fields: [eventSlotId], references: [id])

  // Odpovědi na vlastní otázky (JSON: [{ questionId, label, value }])
  customAnswers   Json?

  // Potvrzení klientem (tlačítko v emailu 24h před)
  confirmationToken    String?   @unique
  confirmedByClientAt  DateTime?

  // Notifikační log (jedna rezervace má víc notifikací)
  notifications NotificationLog[]

  @@index([tenantId])
  @@index([providerId, startsAt])
  @@index([startsAt])
}

// Nemovitost / event (pro makléřský / prohlídkový flow)
model EventListing {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug            String   // /[tenantSlug]/p/[slug]
  title           String
  description     String?
  address         String?
  durationMinutes Int      @default(30)
  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id])
  providerId      String?
  provider        Provider? @relation(fields: [providerId], references: [id])
  // Vlastní otázky — JSON: [{ id, label, type: 'text'|'textarea'|'yesno'|'select'|'number', required, options? }]
  formQuestions   Json     @default("[]")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  slots           EventSlot[]
  bookings        Booking[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// Ručně přidaný slot v rámci nemovitosti
model EventSlot {
  id        String   @id @default(cuid())
  listingId String
  listing   EventListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  booking   Booking?

  @@index([listingId, startsAt])
}

// Konfigurovatelné notifikační pravidlo (jedna sada pro celý tenant)
model NotificationRule {
  id                   String   @id @default(cuid())
  tenantId             String
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Krátký název pravidla (pro orientaci v adminu)
  name                 String
  // Typ kanálu: "email" | "sms"
  channel              String
  // Posun proti začátku schůzky v MINUTÁCH. Záporné = před, kladné = po.
  offsetMinutes        Int
  // Předmět emailu (jen pro email)
  subject              String?
  // Tělo / text. Pro email lze HTML, pro SMS plain. Podporuje proměnné: {{client_name}}, {{service_name}}, {{date}}, {{time}}, {{location}}, {{confirm_url}}, {{business_name}}
  body                 String
  // Přiložit do emailu .ics
  includeIcs           Boolean  @default(false)
  // Přiložit tlačítko / odkaz "Potvrdit"
  includeConfirmButton Boolean  @default(false)
  // Posílat jen pokud klient ještě nepotvrdil (typicky SMS fallback)
  onlyIfNotConfirmed   Boolean  @default(false)
  enabled              Boolean  @default(true)
  order                Int      @default(0)
  createdAt            DateTime @default(now())

  @@index([tenantId])
}

// Log odeslaných notifikací (zabraňuje opakovanému odeslání)
model NotificationLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ruleId    String?
  channel   String   // email | sms
  status    String   // sent | failed | skipped
  error     String?
  sentAt    DateTime @default(now())

  @@index([bookingId])
  @@unique([bookingId, ruleId])
}
