# --- Branding aplikace -------------------------------------------------------
# Tyto hodnoty jsou viditelné v UI (NEXT_PUBLIC_* je dostupné v prohlížeči).
NEXT_PUBLIC_BUSINESS_NAME="Vaše firma"
NEXT_PUBLIC_BUSINESS_TAGLINE="Rezervujte si termín online."
NEXT_PUBLIC_PRIMARY_COLOR="2563eb"

# --- Šablona testovacích dat -------------------------------------------------
# Možnosti: salon | realitka | konzultant
SEED_PRESET="salon"

# Databáze (SQLite pro lokální vývoj)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="vygenerujte-pomoci-openssl-rand-base64-32"

# Resend (email) — https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Rezervace <noreply@vasedomena.cz>"

# GoSMS (SMS) — https://gosms.cz
GOSMS_CLIENT_ID=""
GOSMS_CLIENT_SECRET=""
GOSMS_CHANNEL_ID=""
GOSMS_SENDER=""

# Cron secret pro připomínky
CRON_SECRET="nahodny-token-pro-cron-endpoint"
